{
  "name": "latexsnipper-browser",
  "private": true,
  "version": "1.3.0",
  "description": "LaTeXSnipper Web Formula and AI Conversation Companion",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "typecheck": "tsc --noEmit",
    "test": "node node_modules/vitest/vitest.mjs run",
    "dev": "vite build --watch --mode chrome"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "@types/chrome": "^0.0.300",
    "jsdom": "^26.0.0",
    "vitest": "^3.0.0"
  }
}
