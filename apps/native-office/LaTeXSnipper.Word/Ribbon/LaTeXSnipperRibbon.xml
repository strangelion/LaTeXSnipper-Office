<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperTab" label="LaTeXSnipper" keytip="LS">
        <group id="FormulaGroup" label="Formula">
          <button id="btnInsertInline" label="Insert Inline" size="large" imageMso="EquationProfessional" onAction="OnButtonClick" tag="insertInline"/>
          <button id="btnInsertDisplay" label="Insert Display" size="large" imageMso="EquationInsertGallery" onAction="OnButtonClick" tag="insertDisplay"/>
          <button id="btnInsertNumbered" label="Insert Numbered" size="large" imageMso="Numbering" onAction="OnButtonClick" tag="insertNumbered"/>
          <button id="btnOcrSelector" label="Screenshot OCR" size="large" imageMso="ScreenshotInsertGallery" onAction="OnButtonClick" tag="ocr"/>
        </group>
        <group id="EditGroup" label="Edit">
          <button id="btnLoadSelected" label="Read Selection" size="large" imageMso="ReviewDisplayForReview" onAction="OnButtonClick" tag="readSelection"/>
          <button id="btnDeleteSelected" label="Delete" size="large" imageMso="Delete" onAction="OnButtonClick" tag="delete"/>
        </group>
        <group id="ConversionGroup" label="Conversion">
          <button id="btnToOle" label="To OLE" size="large" imageMso="ObjectEditDialog" onAction="OnButtonClick" tag="toOle"/>
          <button id="btnToOmml" label="To OMML" size="large" imageMso="ConvertTextToTable" onAction="OnButtonClick" tag="toOmml"/>
        </group>
        <group id="ReferenceGroup" label="Reference">
          <button id="btnInsertReference" label="Insert Reference" size="large" imageMso="CrossReferenceInsert" onAction="OnButtonClick" tag="insertReference"/>
        </group>
        <group id="NumberingGroup" label="Numbering">
          <button id="btnAutoNumber" label="Auto Number" size="large" imageMso="NumberingRestart" onAction="OnButtonClick" tag="autoNumber"/>
          <button id="btnRenumber" label="Renumber" size="large" imageMso="RecurrenceEdit" onAction="OnButtonClick" tag="renumber"/>
        </group>
        <group id="BoundaryGroup" label="Boundary">
          <button id="btnChapterBoundary" label="Chapter" size="large" imageMso="BookmarkInsert" onAction="OnButtonClick" tag="chapterBoundary"/>
          <button id="btnSectionBoundary" label="Section" size="large" imageMso="BreaksGallery" onAction="OnButtonClick" tag="sectionBoundary"/>
        </group>
        <group id="FormattingGroup" label="Formatting">
          <button id="btnFormatSelected" label="Format Selected" size="large" imageMso="FormatPainter" onAction="OnButtonClick" tag="formatSelected"/>
          <button id="btnFormatAll" label="Format All" size="large" imageMso="FontDialog" onAction="OnButtonClick" tag="formatAll"/>
        </group>
        <group id="ToolsGroup" label="Tools">
          <button id="btnShowTaskPane" label="Show Pane" size="large" imageMso="ReviewingPane" onAction="OnButtonClick" tag="showPane"/>
          <button id="btnSettings" label="Settings" size="large" imageMso="AdvancedFileProperties" onAction="OnButtonClick" tag="settings"/>
          <button id="btnHelp" label="Help" size="large" imageMso="Help" onAction="OnButtonClick" tag="help"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
