<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperTab" label="LaTeXSnipper" insertAfterMso="TabHome">
        <group id="FormulaGroup" label="Formula">
          <button id="InsertInline" label="Inline" size="large"
                  onAction="OnInsertInline" screentip="Insert inline formula"/>
          <button id="InsertDisplay" label="Display" size="large"
                  onAction="OnInsertDisplay" screentip="Insert display formula"/>
          <button id="InsertNumbered" label="Numbered" size="large"
                  onAction="OnInsertNumbered" screentip="Insert numbered formula"/>
          <separator id="Sep1"/>
          <button id="LoadFormula" label="Load" size="large"
                  onAction="OnLoadFormula" screentip="Load formula from selection"/>
          <button id="DeleteFormula" label="Delete" size="large"
                  onAction="OnDeleteFormula" screentip="Delete current formula"/>
        </group>
        <group id="NumberingGroup" label="Numbering">
          <button id="InsertChapter" label="Chapter" size="large"
                  onAction="OnInsertChapter" screentip="Insert chapter separator"/>
          <button id="InsertSection" label="Section" size="large"
                  onAction="OnInsertSection" screentip="Insert section separator"/>
          <separator id="Sep3"/>
          <button id="Renumber" label="Renumber" size="large"
                  onAction="OnRenumber" screentip="Renumber all formulas"/>
          <button id="InsertReference" label="Reference" size="large"
                  onAction="OnInsertReference" screentip="Insert cross-reference to formula"/>
        </group>
        <group id="TableGroup" label="Table">
          <button id="LoadTable" label="Load Table" size="large"
                  onAction="OnLoadTable" screentip="Load table from selection"/>
          <button id="InsertTable" label="Insert Table" size="large"
                  onAction="OnInsertTable" screentip="Insert table"/>
        </group>
        <group id="FormatGroup" label="Format">
          <button id="FormatSelection" label="Format" size="large"
                  onAction="OnFormatSelection" screentip="Format selected formulas"/>
          <button id="FormatAll" label="Format All" size="large"
                  onAction="OnFormatAll" screentip="Format all formulas in document"/>
        </group>
        <group id="ToolsGroup" label="Tools">
          <button id="OpenEditor" label="Open Editor" size="large"
                  onAction="OnOpenEditor" screentip="Open LaTeXSnipper editor"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
