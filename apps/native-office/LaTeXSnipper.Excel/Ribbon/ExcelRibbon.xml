<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperExcelTab" label="LaTeXSnipper" keytip="LS">
        <group id="FormulaGroup" label="Formula">
          <button id="btnInsertFormula" label="Insert Formula" size="large" imageMso="EquationProfessional" onAction="OnButtonClick" tag="insertFormula" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnOcrSelector" label="Screenshot OCR" size="large" imageMso="ScreenshotInsertGallery" onAction="OnButtonClick" tag="ocr" getEnabled="GetDesktopCommandEnabled"/>
        </group>
        <group id="EditGroup" label="Edit">
          <button id="btnLoadSelected" label="Read Selection" size="large" imageMso="ReviewDisplayForReview" onAction="OnButtonClick" tag="readSelection"/>
          <button id="btnDeleteSelected" label="Delete" size="large" imageMso="Delete" onAction="OnButtonClick" tag="delete"/>
        </group>
        <group id="ToolsGroup" label="Tools">
          <button id="btnShowTaskPane" label="Open LaTeXSnipper" size="large" imageMso="ReviewingPane" onAction="OnButtonClick" tag="showPane" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnSettings" label="Settings" size="large" imageMso="AdvancedFileProperties" onAction="OnButtonClick" tag="settings" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnHelp" label="Help" size="large" imageMso="Help" onAction="OnButtonClick" tag="help"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
