<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/bal">

  <Bundle Name="LaTeXSnipper Native Office"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="F6A7B8C9-AAAA-BBBB-CCCC-DDDDDDDDDDDD"
           Copyright="Copyright (c) LaTeXSnipper 2026">

    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.RtfLicense" />

    <Chain>
      <!-- .NET Framework 4.8 -->
      <ExePackage Id="NetFx48"
                  Name="NetFx48.exe"
                  Cache="keep"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  DownloadUrl="$(var.NetFx48Url)"
                  InstallArguments="/q /norestart"
                  DetectCondition="NetFx48Installed">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="1641" Behavior="success" />
        <ExitCode Value="3010" Behavior="success" />
        <ExitCode Value="5100" Behavior="error" />
      </ExePackage>

      <!-- VSTO Runtime -->
      <ExePackage Id="VstoRuntime"
                  Name="VstoRuntime.exe"
                  Cache="keep"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  DownloadUrl="$(var.VstoRuntimeUrl)"
                  InstallArguments="/quiet /norestart"
                  DetectCondition="VstoRuntimeInstalled">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="1641" Behavior="success" />
        <ExitCode Value="3010" Behavior="success" />
      </ExePackage>

      <!-- Main MSI -->
      <MsiPackage Id="MainMsi"
                  Cache="keep"
                  Vital="yes"
                  SourceFile="$(var.MsiDir)\LaTeXSnipper.NativeOffice.msi"
                  InstallCondition="NOT Installed">
        <MsiProperty Name="INSTALLLOCATION" Value="[InstallFolder]" />
      </MsiPackage>
    </Chain>

  </Bundle>

</Wix>
