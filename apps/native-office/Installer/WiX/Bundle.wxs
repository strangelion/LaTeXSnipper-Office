<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Bundle Name="LaTeXSnipper Native Office"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="F6A7B8C9-AAAA-BBBB-CCCC-DDDDDDDDDDDD"
           Copyright="Copyright (c) LaTeXSnipper 2026">

    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.RtfLicense">
      <bal:WixStandardBootstrapperApplication
        LicenseFile="License.rtf"
        ThemeFile="Theme.xml"
        xmlns:bal="http://wixtoolset.org/schemas/v4/bal" />
    </BootstrapperApplicationRef>

    <!-- Detect .NET Framework 4.8 via registry -->
    <Chain>
      <ExePackage Id="NetFx48"
                  Cache="yes"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  Source="$(var.NetFx48Url)"
                  InstallCommand="/q /norestart"
                  DetectCondition="NetFx48Installed">
        <ExitCode Value="0" Result="Success" />
        <ExitCode Value="1641" Result="Success" />
        <ExitCode Value="3010" Result="Success" />
        <ExitCode Value="5100" Result="Failure" />
      </ExePackage>

      <!-- Install VSTO Runtime if not detected -->
      <ExePackage Id="VstoRuntime"
                  Cache="yes"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  Source="$(var.VstoRuntimeUrl)"
                  InstallCommand="/quiet /norestart"
                  DetectCondition="VstoRuntimeInstalled">
        <ExitCode Value="0" Result="Success" />
        <ExitCode Value="1641" Result="Success" />
        <ExitCode Value="3010" Result="Success" />
      </ExePackage>

      <!-- Main MSI Package -->
      <MsiPackage Id="MainMsi"
                  Cache="yes"
                  Vital="yes"
                  SourceFile="$(var.MsiDir)\LaTeXSnipper.NativeOffice.msi"
                  InstallCondition="NOT Installed">
        <MsiProperty Name="INSTALLLOCATION" Value="[InstallFolder]" />
      </MsiPackage>
    </Chain>

  </Bundle>

</Wix>
