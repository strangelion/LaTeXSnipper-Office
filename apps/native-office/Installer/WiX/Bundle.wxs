<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Bundle Name="LaTeXSnipper Native Office"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="F6A7B8C9-AAAA-BBBB-CCCC-DDDDDDDDDDDD"
           Copyright="Copyright (c) LaTeXSnipper 2026">

    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.RtfLicense">
      <bal:WixStandardBootstrapperApplication
        LicenseFile="License.rtf"
        ThemeFile="Theme.xml"
        xmlns:bal="http://wixtoolset.org/schemas/v4/bal" />
    </BootstrapperApplicationRef>

    <!-- Detect .NET Framework 4.8 via registry (release key) -->
    <Variable Name="NetFx48Installed" Type="numeric" Value="0" />
    <SetVariable Name="NetFx48Installed" Value="1"
      After="DetectNetFx48" />
    <Chain>
      <ExePackage Id="DetectNetFx48" SourceFile="dummy.exe"
                  DetectCondition="NetFx48Installed"
                  InstallCommand="/q /norestart"
                  Permanent="yes" Vital="no" Cache="no" >
        <!-- Registry detection: .NET 4.8 release key -->
        <RegistrySearch Id="NetFx48ReleaseKey" Root="HKLM"
          Key="SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full"
          ValueName="Release" Result="value" />
        <ExitCode Value="0" Result="Success" />
      </ExePackage>

      <!-- Install .NET 4.8 if not detected -->
      <ExePackage Id="NetFx48"
                  Cache="yes"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  Source="$(var.NetFx48Url)"
                  InstallCommand="/q /norestart"
                  DetectCondition="NetFx48Installed">
        <ExitCode Value="0" Result="Success" />
        <ExitCode Value="1641" Result="Success" />
        <ExitCode Value="3010" Result="Success" />
        <ExitCode Value="5100" Result="Failure" />
      </ExePackage>

      <!-- Detect VSTO Runtime via registry -->
      <Variable Name="VstoRuntimeInstalled" Type="numeric" Value="0" />
      <SetVariable Name="VstoRuntimeInstalled" Value="1"
        After="DetectVstoRuntime" />
      <ExePackage Id="DetectVstoRuntime" SourceFile="dummy.exe"
                  DetectCondition="VstoRuntimeInstalled"
                  InstallCommand="/quiet /norestart"
                  Permanent="yes" Vital="no" Cache="no" >
        <!-- Registry detection: VSTO 10.0 -->
        <RegistrySearch Id="VstoRegKey" Root="HKLM"
          Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4.0"
          ValueName="Version" Result="value" />
        <ExitCode Value="0" Result="Success" />
      </ExePackage>

      <!-- Install VSTO Runtime if not detected -->
      <ExePackage Id="VstoRuntime"
                  Cache="yes"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  Source="$(var.VstoRuntimeUrl)"
                  InstallCommand="/quiet /norestart"
                  DetectCondition="VstoRuntimeInstalled">
        <ExitCode Value="0" Result="Success" />
        <ExitCode Value="1641" Result="Success" />
        <ExitCode Value="3010" Result="Success" />
      </ExePackage>

      <!-- Main MSI Package -->
      <MsiPackage Id="MainMsi"
                  Cache="yes"
                  Vital="yes"
                  SourceFile="$(var.MsiDir)\LaTeXSnipper.NativeOffice.msi"
                  InstallCondition="NOT Installed">
        <MsiProperty Name="INSTALLLOCATION" Value="[InstallFolder]" />
      </MsiPackage>
    </Chain>

  </Bundle>

</Wix>
