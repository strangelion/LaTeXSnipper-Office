<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="LaTeXSnipper.NativeOffice"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="E5F6A7B8-9999-AAAA-BBBB-CCCCCCCCCCCC"
           Scope="perUser">

    <SummaryInformation Description="LaTeXSnipper Native Office VSTO Add-in for Word, Excel, and PowerPoint" />

    <!-- Minimal OS requirement -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of LaTeXSnipper Native Office is already installed." />

    <!-- Directory structure -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLDIR" Name="LaTeXSnipper">
        <Directory Id="NativeOfficeDir" Name="NativeOffice">
          <Directory Id="SharedDir" Name="Shared" />
          <Directory Id="WordDir" Name="Word" />
          <Directory Id="ExcelDir" Name="Excel" />
          <Directory Id="PowerPointDir" Name="PowerPoint" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Components -->
    <ComponentGroup Id="ProductComponents" Directory="NativeOfficeDir">

      <!-- Shared Library -->
      <Component Id="SharedComponent" Directory="SharedDir" Guid="A1B2C3D4-1111-2222-3333-444455556666">
        <File Source="$(var.SharedBinDir)\LaTeXSnipper.NativeOffice.Shared.dll" />
        <File Source="$(var.SharedBinDir)\System.Text.Json.dll" />
        <File Source="$(var.SharedBinDir)\System.Text.Encodings.Web.dll" />
        <File Source="$(var.SharedBinDir)\System.Memory.dll" />
        <File Source="$(var.SharedBinDir)\System.Buffers.dll" />
        <File Source="$(var.SharedBinDir)\System.Runtime.CompilerServices.Unsafe.dll" />
        <File Source="$(var.SharedBinDir)\Microsoft.Bcl.AsyncInterfaces.dll" />
      </Component>

      <!-- Word Add-in (with full runtime dependencies) -->
      <Component Id="WordComponent" Directory="WordDir" Guid="B2C3D4E5-2222-3333-4444-555566667777">
        <File Source="$(var.WordBinDir)\LaTeXSnipper.Word.dll" />
        <File Source="$(var.WordBinDir)\LaTeXSnipper.Word.vsto" />
        <File Source="$(var.WordBinDir)\LaTeXSnipper.Word.dll.manifest" />
        <File Source="$(var.SharedBinDir)\LaTeXSnipper.NativeOffice.Shared.dll" />
        <File Source="$(var.SharedBinDir)\System.Text.Json.dll" />

        <!-- VSTO Registry Entries -->
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\Word\Addins\LaTeXSnipper.NativeOffice.Word">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — Word" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for Word" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]Word\LaTeXSnipper.Word.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <!-- Excel Add-in (with full runtime dependencies) -->
      <Component Id="ExcelComponent" Directory="ExcelDir" Guid="C3D4E5F6-3333-4444-5555-666677778888">
        <File Source="$(var.ExcelBinDir)\LaTeXSnipper.Excel.dll" />
        <File Source="$(var.ExcelBinDir)\LaTeXSnipper.Excel.vsto" />
        <File Source="$(var.ExcelBinDir)\LaTeXSnipper.Excel.dll.manifest" />
        <File Source="$(var.SharedBinDir)\LaTeXSnipper.NativeOffice.Shared.dll" />
        <File Source="$(var.SharedBinDir)\System.Text.Json.dll" />

        <!-- VSTO Registry Entries -->
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\Excel\Addins\LaTeXSnipper.NativeOffice.Excel">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — Excel" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for Excel" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]Excel\LaTeXSnipper.Excel.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <!-- PowerPoint Add-in (with full runtime dependencies) -->
      <Component Id="PowerPointComponent" Directory="PowerPointDir" Guid="D4E5F6A7-4444-5555-6666-777788889999">
        <File Source="$(var.PowerPointBinDir)\LaTeXSnipper.PowerPoint.dll" />
        <File Source="$(var.PowerPointBinDir)\LaTeXSnipper.PowerPoint.vsto" />
        <File Source="$(var.PowerPointBinDir)\LaTeXSnipper.PowerPoint.dll.manifest" />
        <File Source="$(var.SharedBinDir)\LaTeXSnipper.NativeOffice.Shared.dll" />
        <File Source="$(var.SharedBinDir)\System.Text.Json.dll" />

        <!-- VSTO Registry Entries -->
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\PowerPoint\Addins\LaTeXSnipper.NativeOffice.PowerPoint">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — PowerPoint" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for PowerPoint" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]PowerPoint\LaTeXSnipper.PowerPoint.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <!-- OLE Formula Object (x86). Only installed when Office is 32-bit. -->
      <Component Id="OleComponentX86" Directory="NativeOfficeDir" Guid="F5A6B7C8-5555-6666-7777-88889999AAAA">
        <File Id="OleDllX86" Source="$(var.OleBinDir)\OleFormulaObject.x86.dll" Name="OleFormulaObject.x86.dll" />
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="Insertable" Value="" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CurVer">
          <RegistryValue Type="string" Value="LaTeXSnipper.Formula.1" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="ProgID" Value="LaTeXSnipper.Formula.1" />
          <RegistryValue Type="string" Name="VersionIndependentProgID" Value="LaTeXSnipper.Formula" />
          <RegistryValue Type="string" Name="Insertable" Value="" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\DefaultIcon">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x86.dll,0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\InprocServer32">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x86.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Apartment" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb">
          <RegistryValue Type="string" Name="0" Value="Edit Formula, 0, 2" />
          <RegistryValue Type="string" Name="1" Value="Open in LaTeXSnipper, 0, 2" />
          <RegistryValue Type="string" Name="2" Value="Copy LaTeX, 0, 0" />
          <RegistryValue Type="string" Name="3" Value="Refresh Preview, 0, 0" />
        </RegistryKey>
      </Component>

      <!-- OLE Formula Object (x64). Only installed when Office is 64-bit. -->
      <Component Id="OleComponentX64" Directory="NativeOfficeDir" Guid="F5A6B7C8-5555-6666-7777-88889999AAAB">
        <File Id="OleDllX64" Source="$(var.OleBinDir)\OleFormulaObject.x64.dll" Name="OleFormulaObject.x64.dll" />
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="Insertable" Value="" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CurVer">
          <RegistryValue Type="string" Value="LaTeXSnipper.Formula.1" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="ProgID" Value="LaTeXSnipper.Formula.1" />
          <RegistryValue Type="string" Name="VersionIndependentProgID" Value="LaTeXSnipper.Formula" />
          <RegistryValue Type="string" Name="Insertable" Value="" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\DefaultIcon">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x64.dll,0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\InprocServer32">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x64.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Apartment" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb">
          <RegistryValue Type="string" Name="0" Value="Edit Formula, 0, 2" />
          <RegistryValue Type="string" Name="1" Value="Open in LaTeXSnipper, 0, 2" />
          <RegistryValue Type="string" Name="2" Value="Copy LaTeX, 0, 0" />
          <RegistryValue Type="string" Name="3" Value="Refresh Preview, 0, 0" />
        </RegistryKey>
      </Component>

    </ComponentGroup>

    <!-- Features -->
    <Feature Id="Complete" Title="LaTeXSnipper Native Office" Level="1">
      <ComponentRef Id="SharedComponent" />
      <ComponentRef Id="WordComponent" />
      <ComponentRef Id="ExcelComponent" />
      <ComponentRef Id="PowerPointComponent" />
      <ComponentRef Id="OleComponentX86" />
      <ComponentRef Id="OleComponentX64" />
    </Feature>

    <!-- WiX v4 built-in installer UI -->
    <ui:WixUI
      Id="WixUI_InstallDir"
      InstallDirectory="INSTALLDIR" />

  </Package>
</Wix>
