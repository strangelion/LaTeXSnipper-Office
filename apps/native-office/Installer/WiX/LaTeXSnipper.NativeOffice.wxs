<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
  xmlns:iis="http://wixtoolset.org/schemas/v4/wxs/iis">

  <!-- HostComponents.wxi is auto-generated by build.ps1 from staging directories.
       It contains one ComponentGroup per host with all DLLs / .vsto / .manifest files. -->
  <?include HostComponents.wxi ?>

  <Package Name="LaTeXSnipper.NativeOffice"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="E5F6A7B8-9999-AAAA-BBBB-CCCCCCCCCCCC"
           Scope="perUser">

    <SummaryInformation Description="LaTeXSnipper Native Office VSTO Add-in for Word, Excel, PowerPoint, and Visio" />

    <MediaTemplate EmbedCab="yes" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of LaTeXSnipper Native Office is already installed." />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLDIR" Name="LaTeXSnipper">
        <Directory Id="NativeOfficeDir" Name="NativeOffice">
          <Directory Id="SharedDir" Name="Shared" />
          <Directory Id="WordDir" Name="Word" />
          <Directory Id="ExcelDir" Name="Excel" />
          <Directory Id="PowerPointDir" Name="PowerPoint" />
          <Directory Id="VisioDir" Name="Visio" />
          <Directory Id="CertificateDir" Name="certificates" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <Binary Id="VstoSigningCertificate" SourceFile="$(var.CertificateDir)\LaTeXSnipperOffice.cer" />

    <ComponentGroup Id="ProductComponents" Directory="NativeOfficeDir">

      <!-- VSTO registry registrations (one per host). Files are in the generated HostComponents.wxi. -->
      <Component Id="WordRegistration" Directory="WordDir" Guid="F1A2B3C4-1111-2222-3333-444455556666">
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\Word\Addins\LaTeXSnipper.NativeOffice.Word">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — Word" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for Word" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]Word\LaTeXSnipper.Word.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <Component Id="ExcelRegistration" Directory="ExcelDir" Guid="F2A3B4C5-1111-2222-3333-444455556667">
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\Excel\Addins\LaTeXSnipper.NativeOffice.Excel">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — Excel" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for Excel" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]Excel\LaTeXSnipper.Excel.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <Component Id="PowerPointRegistration" Directory="PowerPointDir" Guid="F3A4B5C6-1111-2222-3333-444455556668">
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\PowerPoint\Addins\LaTeXSnipper.NativeOffice.PowerPoint">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office — PowerPoint" />
          <RegistryValue Type="string" Name="Description" Value="LaTeX formula and table integration for PowerPoint" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]PowerPoint\LaTeXSnipper.PowerPoint.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <Component Id="VisioRegistration" Directory="VisioDir" Guid="F4A5B6C7-1111-2222-3333-444455556669">
        <RegistryKey Root="HKCU" Key="Software\Microsoft\Office\Visio\Addins\LaTeXSnipper.NativeOffice.Visio">
          <RegistryValue Type="string" Name="FriendlyName" Value="LaTeXSnipper Native Office - Visio" />
          <RegistryValue Type="string" Name="Description" Value="Vector formula integration for Visio" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="integer" Name="CommandLineSafe" Value="0" />
          <RegistryValue Type="string" Name="Manifest" Value="file:///[NativeOfficeDir]Visio\LaTeXSnipper.Visio.vsto|vstolocal" />
        </RegistryKey>
      </Component>

      <!-- Certificate trust -->
      <Component Id="CertificateComponent" Directory="CertificateDir" Guid="E5F6A7B8-5555-6666-7777-88889999AAAC">
        <File Id="VstoCertificateFile" Source="$(var.CertificateDir)\LaTeXSnipperOffice.cer" />
        <File Id="VstoSigningMetadata" Source="$(var.CertificateDir)\native-office-signing.json" />
        <iis:Certificate
          Id="VstoTrustedPublisher"
          Name="LaTeXSnipper Office VSTO Publisher"
          BinaryRef="VstoSigningCertificate"
          Request="no"
          StoreLocation="currentUser"
          StoreName="trustedPublisher"
          Vital="yes" />
      </Component>

      <!-- OLE runtime state -->
      <Component Id="OleRuntimeStateComponent" Directory="NativeOfficeDir" Guid="1E60955A-CA06-4E32-AC21-CB0C4785724E">
        <RegistryKey Root="HKCU" Key="Software\LaTeXSnipper">
          <RegistryValue Type="string" Name="InstallPath" Value="[INSTALLDIR]" KeyPath="yes" />
          <RegistryValue Type="string" Name="RegistrationOwner" Value="LaTeXSnipper.NativeOfficeMSI" />
          <RegistryValue Type="string" Name="InstallId" Value="[ProductCode]" />
          <RegistryValue Type="string" Name="InstallerType" Value="MSI" />
          <RegistryValue Type="string" Name="Version" Value="[ProductVersion]" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\LaTeXSnipper\OfficePlugin\OleFormulaObject"
                     ForceCreateOnInstall="yes" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="integer" Name="InstalledByMsi" Value="1" />
        </RegistryKey>
      </Component>

      <!-- OLE x86 -->
      <Component Id="OleComponentX86" Directory="NativeOfficeDir" Guid="F5A6B7C8-5555-6666-7777-88889999AAAA"
                 Bitness="always32">
        <File Id="OleDllX86" Source="$(var.OleBinDir)\OleFormulaObject.x86.dll" Name="OleFormulaObject.x86.dll" />
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CurVer">
          <RegistryValue Type="string" Value="LaTeXSnipper.Formula.1" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="ProgID" Value="LaTeXSnipper.Formula.1" />
          <RegistryValue Type="string" Name="VersionIndependentProgID" Value="LaTeXSnipper.Formula" />
          <RegistryValue Type="string" Name="RegistrationOwner" Value="LaTeXSnipper.NativeOfficeMSI" />
          <RegistryValue Type="string" Name="InstallId" Value="[ProductCode]" />
          <RegistryValue Type="string" Name="InstallerType" Value="MSI" />
          <RegistryValue Type="string" Name="Version" Value="[ProductVersion]" />
          <RegistryValue Type="string" Name="DllSha256" Value="$(var.OleDllX86Sha256)" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Insertable" ForceCreateOnInstall="yes" ForceDeleteOnUninstall="yes" />
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\DefaultIcon">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x86.dll,0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\InprocServer32">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x86.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Apartment" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\0"><RegistryValue Type="string" Value="Edit Formula, 0, 2" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\1"><RegistryValue Type="string" Value="Open in LaTeXSnipper, 0, 2" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\2"><RegistryValue Type="string" Value="Copy LaTeX, 0, 0" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\3"><RegistryValue Type="string" Value="Refresh Preview, 0, 0" /></RegistryKey>
      </Component>

      <!-- OLE x64 -->
      <Component Id="OleComponentX64" Directory="NativeOfficeDir" Guid="F5A6B7C8-5555-6666-7777-88889999AAAB"
                 Bitness="always64">
        <File Id="OleDllX64" Source="$(var.OleBinDir)\OleFormulaObject.x64.dll" Name="OleFormulaObject.x64.dll" />
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula\CurVer">
          <RegistryValue Type="string" Value="LaTeXSnipper.Formula.1" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\LaTeXSnipper.Formula.1\CLSID">
          <RegistryValue Type="string" Value="{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="LaTeXSnipper Formula Object" />
          <RegistryValue Type="string" Name="ProgID" Value="LaTeXSnipper.Formula.1" />
          <RegistryValue Type="string" Name="VersionIndependentProgID" Value="LaTeXSnipper.Formula" />
          <RegistryValue Type="string" Name="RegistrationOwner" Value="LaTeXSnipper.NativeOfficeMSI" />
          <RegistryValue Type="string" Name="InstallId" Value="[ProductCode]" />
          <RegistryValue Type="string" Name="InstallerType" Value="MSI" />
          <RegistryValue Type="string" Name="Version" Value="[ProductVersion]" />
          <RegistryValue Type="string" Name="DllSha256" Value="$(var.OleDllX64Sha256)" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Insertable" ForceCreateOnInstall="yes" ForceDeleteOnUninstall="yes" />
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\DefaultIcon">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x64.dll,0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\InprocServer32">
          <RegistryValue Type="string" Value="[NativeOfficeDir]OleFormulaObject.x64.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Apartment" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\0"><RegistryValue Type="string" Value="Edit Formula, 0, 2" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\1"><RegistryValue Type="string" Value="Open in LaTeXSnipper, 0, 2" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\2"><RegistryValue Type="string" Value="Copy LaTeX, 0, 0" /></RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\CLSID\{B7F5B4AB-5F94-4D87-A29F-9A41D41B3B9F}\Verb\3"><RegistryValue Type="string" Value="Refresh Preview, 0, 0" /></RegistryKey>
      </Component>

    </ComponentGroup>

    <Feature Id="Complete" Title="LaTeXSnipper Native Office" Level="1">
      <!-- Auto-generated file components from staging directories -->
      <ComponentGroupRef Id="SharedFiles" />
      <ComponentGroupRef Id="WordFiles" />
      <ComponentGroupRef Id="ExcelFiles" />
      <ComponentGroupRef Id="PowerPointFiles" />
      <ComponentGroupRef Id="VisioFiles" />
      <!-- Registry registrations -->
      <ComponentRef Id="WordRegistration" />
      <ComponentRef Id="ExcelRegistration" />
      <ComponentRef Id="PowerPointRegistration" />
      <ComponentRef Id="VisioRegistration" />
      <ComponentRef Id="CertificateComponent" />
      <ComponentRef Id="OleRuntimeStateComponent" />
      <ComponentRef Id="OleComponentX86" />
      <ComponentRef Id="OleComponentX64" />
    </Feature>

    <ui:WixUI
      Id="WixUI_InstallDir"
      InstallDirectory="INSTALLDIR" />

  </Package>
</Wix>
