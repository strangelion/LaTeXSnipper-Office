<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="LaTeXSnipper Native Office (Online Installer)"
           Manufacturer="LaTeXSnipper"
           Version="$(var.Version)"
           UpgradeCode="F6A7B8C9-AAAA-BBBB-CCCC-DDDDDDDDDDDD"
           Copyright="Copyright (c) LaTeXSnipper 2026">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        Theme="hyperlinkLicense"
        LicenseUrl="" />
    </BootstrapperApplication>

    <util:RegistrySearch
      Id="FindNetFx48"
      Variable="NetFx48Release"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full"
      Value="Release"
      Result="value"
      Bitness="always64" />
    <util:RegistrySearch
      Id="FindVstoRuntime64"
      Variable="VstoRuntime64Installed"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4R"
      Value="Version"
      Result="exists"
      Bitness="always64" />
    <util:RegistrySearch
      Id="FindVstoRuntime32"
      Variable="VstoRuntime32Installed"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4R"
      Value="Version"
      Result="exists"
      Bitness="always32" />

    <Chain>
      <!-- .NET Framework 4.8 — downloaded from Microsoft on demand.
           SourceFile is used at build time for metadata (hash/size).
           Compressed="no" + DownloadUrl tells Burn to fetch at install time. -->
      <ExePackage Id="NetFx48"
                  SourceFile="$(var.NetFx48Exe)"
                  Compressed="no"
                  DownloadUrl="$(var.NetFx48Url)"
                  Cache="keep"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  InstallArguments="/q /norestart"
                  DetectCondition="NetFx48Release &gt;= 528040">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="1641" Behavior="success" />
        <ExitCode Value="3010" Behavior="success" />
        <ExitCode Value="5100" Behavior="error" />
      </ExePackage>

      <!-- VSTO Runtime — downloaded from Microsoft on demand -->
      <ExePackage Id="VstoRuntime"
                  SourceFile="$(var.VstoRuntimeExe)"
                  Compressed="no"
                  DownloadUrl="$(var.VstoRuntimeUrl)"
                  Cache="keep"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  InstallArguments="/quiet /norestart"
                  DetectCondition="VstoRuntime64Installed OR VstoRuntime32Installed">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="1641" Behavior="success" />
        <ExitCode Value="3010" Behavior="success" />
      </ExePackage>

      <!-- Main MSI (1.6 MB, always embedded) -->
      <MsiPackage Id="MainMsi"
                  Cache="keep"
                  Vital="yes"
                  SourceFile="$(var.MsiDir)\LaTeXSnipper.NativeOffice.msi" />
    </Chain>

  </Bundle>

</Wix>
