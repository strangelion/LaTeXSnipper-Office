<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperVisioTab" getLabel="GetLabel" keytip="LS">
        <group id="FormulaGroup" getLabel="GetLabel">
          <button id="btnInsertFormula" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="EquationProfessional" onAction="OnButtonClick" tag="insertFormula" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnOcrSelector" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="ScreenshotInsertGallery" onAction="OnButtonClick" tag="ocr" getEnabled="GetDesktopCommandEnabled"/>
        </group>
        <group id="EditGroup" getLabel="GetLabel">
          <button id="btnLoadSelected" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="ReviewDisplayForReview" onAction="OnButtonClick" tag="readSelection"/>
          <button id="btnDeleteSelected" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="Delete" onAction="OnButtonClick" tag="delete"/>
        </group>
        <group id="ToolsGroup" getLabel="GetLabel">
          <button id="btnShowTaskPane" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="ReviewingPane" onAction="OnButtonClick" tag="showPane" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnSettings" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="AdvancedFileProperties" onAction="OnButtonClick" tag="settings" getEnabled="GetDesktopCommandEnabled"/>
          <button id="btnHelp" getLabel="GetLabel" getScreentip="GetScreentip" getSupertip="GetSupertip" size="large" imageMso="Help" onAction="OnButtonClick" tag="help"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
