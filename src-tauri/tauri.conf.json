{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LaTeXSnipper Office",
  "version": "1.0.0",
  "identifier": "com.latexsnipper.office",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:2100",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:office-addin && npm run build:wps && npm run build:native-office && npm run build:vite && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stage-resources.ps1"
  },
  "app": {
    "windows": [
      {
        "title": "LaTeXSnipper Office",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "deb", "rpm"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/OfficeJS/**/*",
      "resources/WPS/**/*",
      "resources/NativeOffice/**/*",
      "resources/Obsidian/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "both",
        "languages": ["english"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
