{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LaTeXSnipper Office",
  "version": "1.2.2",
  "identifier": "com.latexsnipper.office",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:2100",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:office-addin && npm run build:wps && npm run prepare:native-office && npm run build:vite && npm run stage:resources"
  },
  "app": {
    "windows": [
      {
        "title": "LaTeXSnipper Office",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "dmg",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/OfficeJS/**/*",
      "resources/WPS/**/*",
      "resources/Obsidian/**/*",
      "resources/Ecosystem/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "both",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
