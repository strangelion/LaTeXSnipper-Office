<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:type="TaskPaneApp">

  <Id>9a7b3c4d-5e6f-7890-abcd-ef1234567890</Id>
  <Version>1.0.0</Version>
  <ProviderName>LaTeXSnipper</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="LaTeXSnipper"/>
  <Description DefaultValue="LaTeX formula editor for Word - 跨平台公式编辑器"/>

  <!-- App domain -->
  <AppDomains>
    <AppDomain>localhost</AppDomain>
  </AppDomains>

  <!-- Hosts -->
  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <!-- Default settings -->
  <DefaultSettings>
    <!-- Served by LaTeXSnipper Bridge server (port 19876) -->
    <SourceLocation DefaultValue="http://localhost:19876/taskpane/index.html"/>
    <RequestedHeight>400</RequestedHeight>
  </DefaultSettings>

  <!-- Permissions -->
  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
