{
  "manifest_version": 3,
  "name": "LaTeXSnipper",
  "version": "0.1.0",
  "description": "Read, edit and insert LaTeX formulas on the web",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage",
    "clipboardWrite",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:*",
    "http://localhost:*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LaTeXSnipper"
  }
}
