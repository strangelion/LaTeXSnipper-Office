<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperTab" label="LaTeXSnipper" insertBeforeMso="TabAddIns" keytip="LS">
        <group id="LSFormulaGroup" label="Formula">
          <button id="LSInsertInline" label="Inline" size="large" imageMso="EquationProfessional" onAction="LaTeXSnipperRibbon.LSInsertInline" supertip="Insert an inline Word equation" keytip="I"/>
          <button id="LSInsertDisplay" label="Display" size="large" imageMso="EquationInsertGallery" onAction="LaTeXSnipperRibbon.LSInsertDisplay" supertip="Insert a display Word equation" keytip="D"/>
          <button id="LSInsertNumbered" label="Numbered" size="large" imageMso="Numbering" onAction="LaTeXSnipperRibbon.LSInsertNumbered" supertip="Insert a numbered Word equation" keytip="N"/>
          <button id="LSScreenshotOcr" label="OCR" size="large" imageMso="ScreenshotInsertGallery" onAction="LaTeXSnipperRibbon.LSScreenshotOcr" supertip="Open OCR workflow in LaTeXSnipper Office" keytip="O"/>
        </group>
        <group id="LSEditGroup" label="Edit">
          <button id="LSLoadSelection" label="Load Selection" size="large" imageMso="ReviewDisplayForReview" onAction="LaTeXSnipperRibbon.LSLoadSelection" supertip="Load selected Word equation into the editor" keytip="L"/>
          <button id="LSDeleteSelection" label="Delete" size="large" imageMso="Delete" onAction="LaTeXSnipperRibbon.LSDeleteSelection" supertip="Delete the current selection" keytip="X"/>
        </group>
        <group id="LSConvertGroup" label="Convert">
          <button id="LSConvertToOLE" label="To OLE" size="large" imageMso="ObjectEditDialog" onAction="LaTeXSnipperRibbon.LSConvertToOLE" supertip="Requires the native VSTO/OLE plugin"/>
          <button id="LSConvertToWord" label="To Word" size="large" imageMso="ConvertTextToTable" onAction="LaTeXSnipperRibbon.LSConvertToWord" supertip="Requires managed formula metadata"/>
        </group>
        <group id="LSReferenceGroup" label="Reference">
          <button id="LSInsertReference" label="Reference" size="large" imageMso="CrossReferenceInsert" onAction="LaTeXSnipperRibbon.LSInsertReference" supertip="Requires the VSTO metadata model"/>
        </group>
        <group id="LSNumberingGroup" label="Numbering">
          <button id="LSAddNumber" label="Add Number" size="large" imageMso="NumberingRestart" onAction="LaTeXSnipperRibbon.LSAddNumber" supertip="Append a basic equation number" keytip="A"/>
          <button id="LSRenumber" label="Renumber" size="large" imageMso="RecurrenceEdit" onAction="LaTeXSnipperRibbon.LSRenumber" supertip="Reset the basic equation counter" keytip="R"/>
        </group>
        <group id="LSBoundaryGroup" label="Boundaries">
          <button id="LSInsertChapterBoundary" label="Chapter" size="large" imageMso="BookmarkInsert" onAction="LaTeXSnipperRibbon.LSInsertChapterBoundary" supertip="Insert a basic chapter boundary marker"/>
          <button id="LSInsertSectionBoundary" label="Section" size="large" imageMso="BreaksGallery" onAction="LaTeXSnipperRibbon.LSInsertSectionBoundary" supertip="Insert a basic section boundary marker"/>
        </group>
        <group id="LSFormattingGroup" label="Formatting">
          <button id="LSFormatSelection" label="Selection" size="large" imageMso="FormatPainter" onAction="LaTeXSnipperRibbon.LSFormatSelection" supertip="Requires managed formula metadata"/>
          <button id="LSFormatAll" label="All" size="large" imageMso="FontDialog" onAction="LaTeXSnipperRibbon.LSFormatAll" supertip="Requires managed formula metadata"/>
        </group>
        <group id="LSToolsGroup" label="Tools">
          <button id="LSOpenApp" label="Open App" size="large" imageMso="ReviewingPane" onAction="LaTeXSnipperRibbon.LSOpenApp" supertip="Open LaTeXSnipper Office" keytip="P"/>
          <button id="LSSettings" label="Settings" size="large" imageMso="AdvancedFileProperties" onAction="LaTeXSnipperRibbon.LSSettings" supertip="Open LaTeXSnipper Office settings" keytip="S"/>
          <button id="LSShowHelp" label="Help" size="large" imageMso="Help" onAction="LaTeXSnipperRibbon.LSShowHelp" supertip="Show help" keytip="H"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
