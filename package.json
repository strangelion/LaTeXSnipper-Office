{
  "name": "latexsnipper-office",
  "version": "1.0.0",
  "private": true,
  "description": "Independent LaTeX formula editor for Office, Obsidian, WPS, VS Code",
  "scripts": {
    "dev:vite": "vite",
    "build:vite": "vite build",
    "build:office-addin": "powershell -NoProfile -ExecutionPolicy Bypass -File plugin/Office/LightweightAddIn/stage-for-tauri.ps1",
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:desktop": "tauri build --target universal-apple-darwin",
    "build:ios": "tauri ios build",
    "build:android": "tauri android build",
    "lint": "eslint src --ext .js,.ts",
    "format": "prettier --write src/**/*.{js,ts,css}"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "idb": "^8.0.3",
    "mathjax": "^3.2.2",
    "mathlive": "^0.110.0",
    "temml": "^0.13.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.0",
    "vite": "^4.5.14"
  },
  "keywords": [
    "latex",
    "formula",
    "editor",
    "tauri",
    "office",
    "obsidian"
  ],
  "license": "AGPL-3.0-only"
}
