{
  "name": "latexsnipper-office",
  "version": "0.1.0",
  "private": true,
  "description": "Independent LaTeX formula editor for Office, Obsidian, WPS, VS Code",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:desktop": "tauri build --target universal-apple-darwin",
    "build:ios": "tauri ios build",
    "build:android": "tauri android build",
    "lint": "eslint src --ext .js,.ts",
    "format": "prettier --write src/**/*.{js,ts,css}"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "mathlive": "^0.98.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.0",
    "vite": "^4.4.0"
  },
  "keywords": [
    "latex",
    "formula",
    "editor",
    "tauri",
    "office",
    "obsidian"
  ],
  "license": "MIT"
}
