{
  "name": "latexsnipper-office",
  "version": "1.2.8",
  "private": true,
  "description": "Independent LaTeX formula editor for Office, Obsidian, WPS, VS Code",
  "scripts": {
    "dev:vite": "vite",
    "build:vite": "vite build",
    "build:office-addin": "npm --prefix apps/office-addin run build && node scripts/stage-office-addin.mjs",
    "build:wps": "node scripts/build-wps.js",
    "build:native-office": "node scripts/build-native-office.js",
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:desktop": "tauri build --target universal-apple-darwin",
    "build:ios": "tauri ios build",
    "build:android": "tauri android build",
    "lint": "eslint src --ext .js,.ts",
    "format": "prettier --write src/**/*.{js,ts,css}",
    "format:check": "prettier --check src/**/*.{js,ts,css} tests/**/*.mjs scripts/**/*.mjs",
    "typecheck": "tsc -p tsconfig.ci.json",
    "test": "npm run test:frontend",
    "stage:resources": "node scripts/stage-resources.js",
    "prepare:native-office": "node scripts/prepare-native-office.js",
    "check:office-package": "node scripts/check-native-office-package.mjs",
    "check:frontend": "node --check src/main.js",
    "test:frontend": "node --test tests/*.test.mjs",
    "fixtures:mathjax": "node scripts/generate-mathjax-svg-fixtures.mjs",
    "fixtures:mathjax:check": "node scripts/generate-mathjax-svg-fixtures.mjs --check",
    "check:office-payload": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-native-office-payload.ps1 -PayloadRoot apps/native-office/Installer/output/staging",
    "build:obsidian": "npm --prefix apps/obsidian-plugin ci && npm --prefix apps/obsidian-plugin run build -- --production",
    "build:vscode": "npm --prefix apps/vscode-extension ci && npm --prefix apps/vscode-extension run build",
    "build:browser": "npm --prefix apps/browser-extension ci && npm --prefix apps/browser-extension run build",
    "build:ecosystem": "npm run build:obsidian && npm run build:vscode && npm run build:browser",
    "stage:ecosystem": "node scripts/stage-ecosystem-resources.js",
    "package:vscode": "npm --prefix apps/vscode-extension run package",
    "package:obsidian": "node scripts/package-obsidian.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "idb": "^8.0.3",
    "mathjax": "^3.2.2",
    "mathlive": "^0.110.0",
    "temml": "^0.13.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.0",
    "vite": "^4.5.14",
    "mathjax-full": "3.2.2"
  },
  "keywords": [
    "latex",
    "formula",
    "editor",
    "tauri",
    "office",
    "obsidian"
  ],
  "license": "AGPL-3.0-only"
}
